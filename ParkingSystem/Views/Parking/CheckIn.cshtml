@model ParkingSystem.Models.ParkingTransaction

@{
    ViewData["Title"] = "Parkir Masuk";
}

<div class="container mt-4">

    <div class="card shadow">

        <div class="card-header bg-success text-white">
            <h3>Parkir Masuk</h3>
        </div>

        <div class="card-body">

            <form asp-action="CheckIn" method="post">

                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="mb-3">

                    <label asp-for="VehicleId" class="form-label"></label>

                    <select asp-for="VehicleId"
                            asp-items="ViewBag.VehicleId"
                            class="form-select">

                        <option value="">-- Pilih Kendaraan --</option>

                    </select>

                    <span asp-validation-for="VehicleId" class="text-danger"></span>

                </div>

                <div class="mb-3">

                    <label asp-for="OfficerId" class="form-label"></label>

                    <select asp-for="OfficerId"
                            asp-items="ViewBag.OfficerId"
                            class="form-select">

                        <option value="">-- Pilih Petugas --</option>

                    </select>

                    <span asp-validation-for="OfficerId" class="text-danger"></span>

                </div>

                <button type="submit" class="btn btn-success">
                    Simpan
                </button>

                <a asp-action="Index" class="btn btn-secondary">
                    Kembali
                </a>

            </form>

        </div>

    </div>

</div>

@section Scripts{
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
