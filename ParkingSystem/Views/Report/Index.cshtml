@model IEnumerable<ParkingSystem.Models.ParkingTransaction>

@{
    ViewData["Title"] = "Laporan Parkir";
}

<div class="container mt-4">

    <div class="card shadow">

        <div class="card-header bg-primary text-white">
            <h3>Laporan Parkir</h3>
        </div>

        <div class="card-body">

            <form method="get" class="row mb-3">

                <div class="col-md-3">
                    <input type="date"
                           name="startDate"
                           value="@ViewBag.StartDate"
                           class="form-control" />
                </div>

                <div class="col-md-3">
                    <input type="date"
                           name="endDate"
                           value="@ViewBag.EndDate"
                           class="form-control" />
                </div>

                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary">
                        Filter
                    </button>
                </div>

                <div class="col-md-2">
                    <a asp-action="Print"
                       asp-route-startDate="@ViewBag.StartDate"
                       asp-route-endDate="@ViewBag.EndDate"
                       class="btn btn-danger">
                        Cetak PDF
                    </a>
                </div>

            </form>

            <table class="table table-bordered table-hover">

                <thead class="table-dark">

                    <tr>
                        <th>No Polisi</th>
                        <th>Petugas</th>
                        <th>Masuk</th>
                        <th>Keluar</th>
                        <th>Status</th>
                        <th>Total</th>
                    </tr>

                </thead>

                <tbody>

                    @if (Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr>

                                <td>@item.Vehicle?.PlateNumber</td>

                                <td>@item.Officer?.Name</td>

                                <td>@item.EntryTime.ToString("dd/MM/yyyy HH:mm")</td>

                                <td>
                                    @(item.ExitTime?.ToString("dd/MM/yyyy HH:mm") ?? "-")
                                </td>

                                <td>
                                    @item.Status
                                </td>

                                <td>
                                    Rp @item.TotalFee.ToString("N0")
                                </td>

                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center">
                                Belum ada data transaksi.
                            </td>
                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>
