@model ParkingSystem.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<div class="container-fluid">

    <h2 class="mb-4">Dashboard</h2>

    <div class="row">

        <div class="col-md-3 mb-3">

            <div class="card text-white bg-primary shadow">

                <div class="card-body">

                    <h5>Total Kendaraan</h5>

                    <h2>@Model.TotalVehicles</h2>

                </div>

            </div>

        </div>

        <div class="col-md-3 mb-3">

            <div class="card text-white bg-success shadow">

                <div class="card-body">

                    <h5>Total Petugas</h5>

                    <h2>@Model.TotalOfficers</h2>

                </div>

            </div>

        </div>

        <div class="col-md-3 mb-3">

            <div class="card text-white bg-warning shadow">

                <div class="card-body">

                    <h5>Sedang Parkir</h5>

                    <h2>@Model.TotalParking</h2>

                </div>

            </div>

        </div>

        <div class="col-md-3 mb-3">

            <div class="card text-white bg-danger shadow">

                <div class="card-body">

                    <h5>Pendapatan Hari Ini</h5>

                    <h2>Rp @Model.TodayIncome.ToString("N0")</h2>

                </div>

            </div>

        </div>

    </div>

</div>
